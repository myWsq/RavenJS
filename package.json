{
  "name": "raven.js",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "build": "pnpm --filter @raven.js/core build",
    "benchmark": "pnpm benchmark:micro && pnpm benchmark:e2e",
    "benchmark:micro": "tsx benchmark/micro/validator.bench.ts && tsx benchmark/micro/state.bench.ts",
    "benchmark:e2e": "tsx benchmark/e2e/throughput.bench.ts",
    "benchmark:compare": "tsx benchmark/compare/frameworks.bench.ts",
    "release": "tsx scripts/release.ts",
    "prepare": "husky",
    "fmt": "oxfmt"
  },
  "devDependencies": {
    "@clack/prompts": "^1.0.1",
    "@hono/node-server": "^2.0.4",
    "@types/node": "^22.0.0",
    "ajv": "^8.18.0",
    "elysia": "^1.4.25",
    "hono": "^4.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "mitata": "^1.0.34",
    "oxfmt": "^0.35.0",
    "tsdown": "^0.22.2",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^3.0.0",
    "zod": "^4.3.6"
  }
}
