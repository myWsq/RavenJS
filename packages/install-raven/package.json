{
  "name": "install-raven",
  "version": "1.2.3",
  "description": "Install RavenJS AI skills into your project",
  "type": "module",
  "bin": {
    "install-raven": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build main.ts --outfile=dist/cli.js --target=node && cp -r skills dist/"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "commander": "^12.0.0"
  },
  "keywords": [
    "ravenjs",
    "skills",
    "claude",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/myWsq/RavenJS.git"
  }
}
